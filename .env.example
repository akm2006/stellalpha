# Stellalpha environment example
# Copy to .env.local for local development.
# Use the same values for Vercel and the worker deployment where applicable.

# Core app + API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET=sb_secret_your_secret_key
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_service_role_key
IRON_SESSION_PASSWORD=change_me_to_a_long_random_secret_at_least_32_chars
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id
HELIUS_API_KEY=your_helius_api_key
HELIUS_API_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
HELIUS_GATEKEEPER_ENABLED=false
HELIUS_GATEKEEPER_RPC_URL=
JUPITER_API_KEY=your_jupiter_api_key
HELIUS_WEBHOOK_SECRET=your_random_webhook_secret

# Worker
SHYFT_API_KEY=your_shyft_api_key
YELLOWSTONE_GRPC_URL=https://your-yellowstone-endpoint
PUBLICNODE_YELLOWSTONE_ENDPOINT=
YELLOWSTONE_X_TOKEN=your_yellowstone_token
PUBLICNODE_YELLOWSTONE_TOKEN=
PUBLICNODE_TOKEN=

# Scheduled routes
CRON_SECRET=your_random_cron_secret
COPY_SIGNAL_SAFE_BOOST_ENABLED=false

# Live pilot (optional)
PILOT_OPERATOR_WALLETS=wallet_pubkey_1,wallet_pubkey_2
PILOT_WALLET_A_ALIAS=wallet-a
PILOT_WALLET_A_PUBLIC_KEY=pilot_wallet_a_pubkey
PILOT_WALLET_A_SECRET=pilot_wallet_a_base58_secret
PILOT_WALLET_A_STAR_TRADER=trusted_star_trader_wallet_a
PILOT_WALLET_B_ALIAS=wallet-b
PILOT_WALLET_B_PUBLIC_KEY=pilot_wallet_b_pubkey
PILOT_WALLET_B_SECRET=pilot_wallet_b_base58_secret
PILOT_WALLET_B_STAR_TRADER=trusted_star_trader_wallet_b
PILOT_FEE_RESERVE_PCT=0.10
PILOT_MIN_FEE_RESERVE_SOL=0.05
PILOT_MIN_TRADE_SIZE_SOL=0.02
PILOT_MAX_TRADE_BUYPOWER_PCT=0.10
PILOT_BUY_MAX_PRICE_IMPACT_PCT=0
PILOT_BUY_MAX_REQUOTES=1
PILOT_SELL_SLIPPAGE_RETRY_BPS=200
PILOT_EXIT_PROTECTION_FAILURE_THRESHOLD=2
PILOT_EXIT_PROTECTION_WINDOW_MINUTES=10
PILOT_TELEGRAM_BOT_TOKEN=
PILOT_TELEGRAM_CHAT_ID=

