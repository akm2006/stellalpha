# Stellalpha environment example
# Copy to .env.local for local development. The Next.js app and `pnpm worker`
# both read from the same env file in this repo.

# ---------------------------------------------------------------------------
# Web app service
# UI + API routes under app/api/*, including demo vault simulation and webhook.
# ---------------------------------------------------------------------------

# [required] Shared Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co

# [required] Server-side Supabase key used throughout the app.
SUPABASE_SECRET=sb_secret_your_secret_key

# [optional, recommended] Preferred admin key for auth verification flows.
# If omitted, server-admin falls back to SUPABASE_SECRET.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_service_role_key

# [required] iron-session password. Use a long random string (32+ chars).
IRON_SESSION_PASSWORD=change_me_to_a_long_random_secret_at_least_32_chars

# [required] Reown/AppKit project id for wallet auth in the frontend.
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id

# [required] Helius API key for portfolio APIs, reconcile, and worker fallback fetches.
HELIUS_API_KEY=your_helius_api_key

# [optional, recommended] Explicit Helius RPC URL for reconcile/worker RPC calls.
# If omitted, some code falls back to a URL derived from HELIUS_API_KEY, but
# the follower V2 equity model is disabled.
HELIUS_API_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# [required] Jupiter API key for quote/simulation routes and token metadata.
JUPITER_API_KEY=your_jupiter_api_key

# [required] Shared secret expected by /api/helius-webhook.
HELIUS_WEBHOOK_SECRET=your_random_webhook_secret

# ---------------------------------------------------------------------------
# Worker service
# `pnpm worker` also needs the shared vars above:
# SUPABASE_URL, SUPABASE_SECRET, HELIUS_API_KEY, HELIUS_API_RPC_URL
# ---------------------------------------------------------------------------

# [required] SHYFT API key for parsed transaction fetching.
SHYFT_API_KEY=your_shyft_api_key

# [required, choose one style] Yellowstone gRPC endpoint for the ingestion
# worker, or PublicNode's Yellowstone-compatible endpoint.
YELLOWSTONE_GRPC_URL=https://your-yellowstone-endpoint
# PUBLICNODE_YELLOWSTONE_ENDPOINT=https://your-publicnode-yellowstone-endpoint

# [required, choose one style] Yellowstone auth token for the worker, or the
# PublicNode equivalent. PUBLICNODE_TOKEN is also accepted as a fallback.
YELLOWSTONE_X_TOKEN=your_yellowstone_token
# PUBLICNODE_YELLOWSTONE_TOKEN=your_publicnode_yellowstone_token
# PUBLICNODE_TOKEN=your_publicnode_token

# ---------------------------------------------------------------------------
# Cron / scheduled routes
# Scheduled requests hit the Next.js app over HTTP and still require auth.
# Reconcile / cleanup also use the shared app vars above.
# ---------------------------------------------------------------------------

# [required in production] Bearer token for /api/cron/reconcile and
# /api/cron/cleanup-trades.
CRON_SECRET=your_random_cron_secret

