# Stellalpha environment example
# Copy to .env.local for local development.
# Use the same values for Vercel and the worker deployment where applicable.

# Core app + API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET=sb_secret_your_secret_key
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_service_role_key
SUPABASE_FETCH_TIMEOUT_MS=10000
# Optional direct Postgres path for live-pilot hot-path reads/writes.
# Use Supabase Session Pooler/Transaction Pooler URL for Railway workers, not PostgREST.
LIVE_PILOT_DATABASE_URL=
LIVE_PILOT_PG_POOL_MAX=5
LIVE_PILOT_PG_CONNECTION_TIMEOUT_MS=5000
LIVE_PILOT_PG_IDLE_TIMEOUT_MS=30000
LIVE_PILOT_PG_QUERY_TIMEOUT_MS=10000
LIVE_PILOT_PG_APPLICATION_NAME=stellalpha-live-pilot

# Optional Redis hot path for live-pilot execution control.
# In Railway, set REDIS_URL from the Redis service reference, e.g. ${{Redis.REDIS_URL}}.
REDIS_URL=
LIVE_PILOT_REDIS_ENABLED=false
LIVE_PILOT_REDIS_EXECUTION_ENABLED=false
LIVE_PILOT_REDIS_MIRROR_ENABLED=true
LIVE_PILOT_REDIS_CONSUMER_GROUP=live-pilot-executors
LIVE_PILOT_REDIS_STREAM_MAXLEN=50000
LIVE_PILOT_REDIS_LOCK_TTL_MS=15000
LIVE_PILOT_REDIS_LOCK_EXTEND_MS=8000
LIVE_PILOT_REDIS_PENDING_IDLE_MS=30000
LIVE_PILOT_REDIS_MAX_DELIVERIES=3
LIVE_PILOT_REDIS_DEDUPE_TTL_SECONDS=604800
LIVE_PILOT_REDIS_READ_BLOCK_MS=250
LIVE_PILOT_REDIS_READ_COUNT=10
IRON_SESSION_PASSWORD=change_me_to_a_long_random_secret_at_least_32_chars
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id
HELIUS_API_KEY=your_helius_api_key
HELIUS_API_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
HELIUS_GATEKEEPER_ENABLED=false
HELIUS_GATEKEEPER_RPC_URL=

# Jupiter API keys
# JUPITER_API_KEY is used by demo simulation, UI price lookups, and token metadata.
# JUPITER_LIVE_API_KEY is optional and used only by live-pilot execution.
# For real quota isolation, use a live key from a separate Jupiter account/project.
JUPITER_API_KEY=your_demo_and_data_jupiter_api_key
JUPITER_LIVE_API_KEY=your_live_execution_jupiter_api_key
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
JUPITER_LIVE_BUY_ORDER_TIMEOUT_MS=2500
JUPITER_LIVE_BUY_EXECUTE_TIMEOUT_MS=2500
JUPITER_LIVE_SELL_ORDER_TIMEOUT_MS=6000
JUPITER_LIVE_SELL_EXECUTE_TIMEOUT_MS=6000
HELIUS_WEBHOOK_SECRET=your_random_webhook_secret

# Worker
SHYFT_API_KEY=your_shyft_api_key
YELLOWSTONE_GRPC_URL=https://your-yellowstone-endpoint
PUBLICNODE_YELLOWSTONE_ENDPOINT=
YELLOWSTONE_X_TOKEN=your_yellowstone_token
PUBLICNODE_YELLOWSTONE_TOKEN=
PUBLICNODE_TOKEN=

# Scheduled routes
CRON_SECRET=your_random_cron_secret
COPY_SIGNAL_SAFE_BOOST_ENABLED=false
LIVE_PILOT_FAST_LANE_ENABLED=true
LIVE_PILOT_SOL_BALANCE_CACHE_TTL_MS=1500
LIVE_PILOT_TOKEN_BALANCE_CACHE_TTL_MS=1500

# Live pilot (optional)
PILOT_OPERATOR_WALLETS=wallet_pubkey_1,wallet_pubkey_2
PILOT_WALLET_A_ALIAS=wallet-a
PILOT_WALLET_A_PUBLIC_KEY=pilot_wallet_a_pubkey
PILOT_WALLET_A_SECRET=pilot_wallet_a_base58_secret
PILOT_WALLET_A_STAR_TRADER=trusted_star_trader_wallet_a
PILOT_WALLET_B_ALIAS=wallet-b
PILOT_WALLET_B_PUBLIC_KEY=pilot_wallet_b_pubkey
PILOT_WALLET_B_SECRET=pilot_wallet_b_base58_secret
PILOT_WALLET_B_STAR_TRADER=trusted_star_trader_wallet_b
PILOT_FEE_RESERVE_PCT=0.10
PILOT_MIN_FEE_RESERVE_SOL=0.05
PILOT_MIN_TRADE_SIZE_SOL=0.02
PILOT_MAX_TRADE_BUYPOWER_PCT=0.10
PILOT_BUY_MAX_PRICE_IMPACT_PCT=0
PILOT_BUY_MAX_REQUOTES=1
PILOT_SELL_SLIPPAGE_RETRY_BPS=200
PILOT_EXIT_PROTECTION_FAILURE_THRESHOLD=2
PILOT_EXIT_PROTECTION_WINDOW_MINUTES=10
PILOT_TELEGRAM_BOT_TOKEN=
PILOT_TELEGRAM_CHAT_ID=

